(define limit 10)
(type num (range 1 limit))
(type cell (for i num (set (cell i))))

(observed
 (all i num (< num limit)
      (next (cell i) (cell (+ 1 i))))

 (all (a b) cell (next a b)
      (smaller a b))

 (all (a b c) cell (and (smaller a b) (smaller b c))
      (smaller a c))
 )

(for (a b) (smaller a b) (non-observed-smaller a b))
 
