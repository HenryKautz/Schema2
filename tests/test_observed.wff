(alias limit 10)
(domain num (range 1 limit))
(domain cell (for i num (set (cell i))))

(observed
 (all i num (< i limit)
      (next (cell i) (cell (+ 1 i))))

 (all (a b) cell (next a b)
      (smaller a b))

 (all (a b c) cell (and (smaller a b) (smaller b c))
      (smaller a c))
 )

(all (a b) cell (smaller a b) (non-observed-smaller a b))
 
